# 🌙 Luna — Environment Configuration

Copy this file to `.env` and fill in your values.

# === Casper x402 ===
# Casper wallet address for receiving payment (66 hex chars with 00 prefix)
LUNA_CASPER_WALLET_ADDRESS=

# CSPR.cloud x402 facilitator API key
CSPR_CLOUD_API_KEY=

# Casper network (default: casper:casper-test)
# CASPER_NETWORK=casper:casper-test

# Casper MCP server for agent discovery
# CASPER_MCP_SERVER_URL=

# === EVM / Base ===
# Luna's EVM wallet private key for ERC-8004 registration
LUNA_EVM_PRIVATE_KEY=

# ERC-8004 Identity Registry contract on Base Sepolia
# ERC8004_IDENTITY_REGISTRY=0x...

# Luna's EVM wallet address (derived from private key)
# LUNA_EVM_WALLET=0x...

# === AllFans ===
# AllFans backend API URL
# ALLFANS_API_URL=http://localhost:3000

# AllFans API key (if required)
# ALLFANS_API_KEY=

# Mock mode — true returns mock data, no AllFans backend needed
# ALLFANS_MOCK_MODE=true

# === LLM ===
# Venice AI API key (for NLU engine)
# VENICE_API_KEY=

# Venice model (default: llama-3.3-70b)
# VENICE_MODEL=llama-3.3-70b

# Google Gemini API key (fallback, free tier: 1500 req/day)
# GEMINI_API_KEY=

# OpenRouter API key (fallback, pay-as-you-go)
# OPENROUTER_API_KEY=

# Groq API key (fallback, free tier: 30 req/min)
# GROQ_API_KEY=

# OpenAI API key (fallback, paid)
# OPENAI_API_KEY=

# === Server ===
# Port (default: 3002)
# PORT=3002
