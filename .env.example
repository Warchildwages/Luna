# Luna — Environment Variables
# Your fans, your Luna. 🌙

# ===================== Required =====================

# Casper x402 Configuration
LUNA_CASPER_WALLET_ADDRESS=        # Casper wallet — receives x402 payments
CSPR_CLOUD_API_KEY=                 # CSPR.cloud — authenticates with x402 Facilitator

# ===================== Optional =====================

# Casper Network (default: casper:casper-test)
# CASPER_NETWORK=casper:casper-test

# Casper x402 Facilitator URL (default: https://x402-facilitator.cspr.cloud)
# CASPER_FACILITATOR_URL=https://x402-facilitator.cspr.cloud

# AllFans Platform API (default: http://localhost:3000)
# ALLFANS_API_URL=http://localhost:3000
# ALLFANS_API_KEY=

# Dev Mode — mock AllFans responses, no backend needed
# ALLFANS_MOCK_MODE=true

# ERC-8004 Registration on Base (for EVM agent discovery)
# ERC8004_IDENTITY_REGISTRY=        # ERC-8004 Identity Registry contract on Base
# LUNA_EVM_WALLET=                   # Luna's EVM wallet on Base
# LUNA_EVM_PRIVATE_KEY=              # Private key for EVM wallet

# Casper MCP Server (for agent discovery on Casper)
# CASPER_MCP_SERVER_URL=

# Agent Wallet Secret Key (for signing Casper deploys)
# LUNA_CASPER_SECRET_KEY=
